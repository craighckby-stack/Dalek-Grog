// GrogEventDispatcher.ts
import { Logger } from './Logger';
import { GrogMediator } from './GrogMediator';

class GrogEventDispatcher {
  private handlers: Map<string, (event: any) => void>;
  private mediator: GrogMediator;

  constructor() {
    this.handlers = new Map();
    this.mediator = new GrogMediator();
  }

  #newContribution(event: any) {
    this.handlers.get('NEW_CONTRIBUTION')(event);
  }

  #updateCode(event: any) {
    this.handlers.get('UPDATE_CODE')(event);
  }

  dispatchEvent(event: any) {
    switch (event.type) {
      case 'NEW_CONTRIBUTION':
        this.#newContribution(event);
        break;
      case 'UPDATE_CODE':
        this.#updateCode(event);
        break;
      default:
        this.mediator.error(`Unknown event type: ${event.type}`);
    }
  }
}

// GrogMediator.ts
import { GrogEventDispatcher } from './GrogEventDispatcher';
import { GrogCommandExecutor } from './GrogCommandExecutor';
import { GrogQueryExecutor } from './GrogQueryExecutor';
import { Logger } from './Logger';

class GrogMediator {
  private eventDispatcher: GrogEventDispatcher;
  private commandExecutor: GrogCommandExecutor;
  private queryExecutor: GrogQueryExecutor;
  private logger: Logger;

  constructor() {
    this.eventDispatcher = new GrogEventDispatcher();
    this.commandExecutor = new GrogCommandExecutor();
    this.queryExecutor = new GrogQueryExecutor();
    this.logger = new Logger();
  }

  error(message: any) {
    if (this.logger.isDebugEnabled()) {
      this.logger.error(message);
    }
  }

  executeCommand(command: any) {
    return this.commandExecutor.execute(command);
  }

  executeQuery(query: any) {
    return this.queryExecutor.execute(query);
  }

  dispatchEvent(event: any) {
    this.eventDispatcher.dispatchEvent(event);
  }
}

