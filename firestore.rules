rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "Craighckby@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidDeath(data) {
      return data.keys().hasAll(['id', 'timestamp', 'reason']) &&
             data.reason is string && data.reason.size() < 1000;
    }

    function isValidLesson(data) {
      return data.keys().hasAll(['id', 'timestamp', 'lesson']) &&
             data.lesson is string && data.lesson.size() < 2000;
    }

    // GrogBrain Source Code
    match /system/grog-brain {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Shared Consciousness Data
    match /deaths/{deathId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidDeath(request.resource.data);
    }

    match /lessons/{lessonId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidLesson(request.resource.data);
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId;
    }
  }
}
