/**
 * @file LICENSE.ts
 * @package Nexus_Core
 * @version 3.1.0
 * @description Programmatic MIT License implementation with hierarchical Architectural Attribution and Diagnostic Traceability.
 */

/**
 * @enum LicenseFlags
 * Bitwise representation of permissions and usage constraints.
 */
export enum LicenseFlags {
    None                = 0,
    Import              = 1 << 0,
    Modification        = 1 << 1,
    Merge               = 1 << 2,
    Publish             = 1 << 3,
    Distribute          = 1 << 4,
    Sublicense          = 1 << 5,
    CommercialUse       = 1 << 6,
    PrivateUse          = 1 << 7,
    GlobalUse           = 1 << 8,
    RecursiveUsage      = 1 << 9,
    AttributionRequired = 1 << 10,
    IntegrityLocked     = 1 << 11,
    LegacyLogic         = 1 << 12,
    All                 = (1 << 13) - 1
}

/**
 * @enum DiagnosticSeverity
 * Classification of system diagnostics and integrity failures.
 */
export enum DiagnosticSeverity {
    Hint,
    Suggestion,
    Message,
    Warning,
    Error,
    Fatal
}

/**
 * @enum AcquisitionMethod
 * Categorization of architectural pattern acquisition.
 */
export enum AcquisitionMethod {
    DirectFetch,
    ArchiveRecovery,
    SearchDiscovery,
    PreAiSiphon,
    RecursiveEvolution
}

/**
 * @interface DiagnosticChain
 * Recursive structure for tracking diagnostic events and causal links.
 */
export interface DiagnosticChain {
    message: string;
    severity: DiagnosticSeverity;
    code: number;
    reports?: DiagnosticChain[];
    context?: string;
}

/**
 * @interface AcquisitionManifest
 * Metadata regarding the lineage of acquired architectural patterns.
 */
export interface AcquisitionManifest {
    method: AcquisitionMethod;
    originUrl: string;
    timestamp: number;
    depth: number;
}

/**
 * @interface ArchitecturalSymbol
 * Metadata for external architectural contributions and dependencies.
 */
export interface ArchitecturalSymbol {
    readonly id: string;
    readonly repository: string;
    readonly contribution: string;
    readonly timestamp: number;
    readonly checksum: string;
    readonly flags: LicenseFlags;
    readonly manifest: AcquisitionManifest;
    readonly dependencies?: string[];
    readonly metadata?: Record<string, any>;
}

/**
 * @interface BootstrapConfig
 * Configuration surface for the license system bootstrap sequence.
 */
export interface BootstrapConfig {
    /** Copyright holder name */
    holder: string;
    /** Copyright year */
    year: string;
    /** Initial architectural symbols to seed the registry with */
    symbols?: ArchitecturalSymbol[];
    /** Permission flags to validate at boot. Defaults to full MIT set. */
    activeFlags?: LicenseFlags;
    /** If true, a failed compliance check throws rather than returning a result object */
    strictMode?: boolean;
}

/**
 * @interface BootstrapResult
 * Outcome of a completed bootstrap sequence.
 */
export interface BootstrapResult {
    success: boolean;
    license: string | null;
    diagnostics: readonly DiagnosticChain[];
    symbolCount: number;
    /** Resolved service references for downstream consumers */
    services: {
        registry: SymbolRegistry;
        validator: ComplianceValidator;
        emitter: LicenseEmitter;
    };
}

// ─────────────────────────────────────────────────────────────────────────────
// Core classes (unchanged from v3.0.0)
// ─────────────────────────────────────────────────────────────────────────────

/**
 * @class DependencyContainer
 * Service registry for core licensing and validation components.
 */
export class DependencyContainer {
    private static services: Map<string, any> = new Map();

    public static register<T>(name: string, instance: T): void {
        this.services.set(name, instance);
    }

    public static resolve<T>(name: string): T {
        const service = this.services.get(name);
        if (!service) throw new Error(`Resolution Failure: ${name}`);
        return service as T;
    }

    /** Tear down all registered services. Use between test runs or hot-reloads. */
    public static reset(): void {
        this.services.clear();
    }
}

/**
 * @class SymbolRegistry
 * Registry for managing architectural symbols and diagnostic state.
 * Fixed: initial data now passed via constructor rather than referencing
 * an undeclared global ARCHITECTURAL_DATA.
 */
export class SymbolRegistry {
    private symbolRegistry: Map<string, ArchitecturalSymbol> = new Map();
    private diagnostics: DiagnosticChain[] = [];
    private isValid: boolean = true;

    constructor(initialSymbols: ArchitecturalSymbol[] = []) {
        initialSymbols.forEach(symbol => this.registerSymbol(symbol));
    }

    public registerSymbol(symbol: ArchitecturalSymbol): void {
        if (symbol.checksum.length < 64) {
            this.reportDiagnostic({
                code: 8001,
                severity: DiagnosticSeverity.Warning,
                message: `Insufficient checksum length for symbol: ${symbol.id}`
            });
        }

        if (this.symbolRegistry.has(symbol.id)) {
            this.reportDiagnostic({
                code: 9001,
                severity: DiagnosticSeverity.Error,
                message: `Collision: Symbol ${symbol.id} is already registered.`
            });
            return;
        }

        this.symbolRegistry.set(symbol.id, symbol);
    }

    public reportDiagnostic(diag: DiagnosticChain): void {
        this.diagnostics.push(diag);
        if (diag.severity >= DiagnosticSeverity.Error) {
            this.isValid = false;
        }
    }

    public getSymbol(id: string): ArchitecturalSymbol | undefined {
        return this.symbolRegistry.get(id);
    }

    public getDiagnostics(): readonly DiagnosticChain[] {
        return this.diagnostics;
    }

    public listSymbols(): ArchitecturalSymbol[] {
        return Array.from(this.symbolRegistry.values());
    }

    public getStatus(): boolean {
        return this.isValid;
    }
}

/**
 * @class ComplianceValidator
 * Validates runtime compliance against permission flags and integrity constraints.
 */
export class ComplianceValidator {
    private registry: SymbolRegistry;

    constructor() {
        this.registry = DependencyContainer.resolve<SymbolRegistry>('SymbolRegistry');
    }

    public validatePermissions(activeFlags: LicenseFlags): boolean {
        const required = LicenseFlags.Import | LicenseFlags.Merge | LicenseFlags.AttributionRequired;

        if ((activeFlags & required) !== required) {
            this.registry.reportDiagnostic({
                code: 5005,
                severity: DiagnosticSeverity.Fatal,
                message: "Compliance failure: Required permission flags missing.",
                reports: [{
                    code: 5006,
                    severity: DiagnosticSeverity.Suggestion,
                    message: "Ensure AttributionRequired flag is present."
                }]
            });
            return false;
        }
        return true;
    }

    public validateIntegrity(): boolean {
        return this.registry.listSymbols().every(s => s.checksum.length === 64);
    }
}

/**
 * @class LicenseEmitter
 * Generates standardized legal notices with embedded architectural attributions.
 */
export class LicenseEmitter {
    private registry: SymbolRegistry;
    private validator: ComplianceValidator;

    constructor() {
        this.registry = DependencyContainer.resolve<SymbolRegistry>('SymbolRegistry');
        this.validator = DependencyContainer.resolve<ComplianceValidator>('ComplianceValidator');
    }

    public emit(holder: string, year: string): string {
        if (!this.validator.validateIntegrity()) {
            return "ERROR: Integrity validation failed. License emission terminated.";
        }

        const attributionSection = this.generateAttributionSection();
        const diagnosticSection  = this.generateDiagnosticSection();

        return this.getLicenseTemplate(holder, year, attributionSection, diagnosticSection);
    }

    private generateAttributionSection(): string {
        return this.registry.listSymbols()
            .map(s => ` [ID:${s.checksum.substring(0, 12)}] [URL:${s.manifest.originUrl}] ${s.repository}: ${s.contribution}`)
            .join('\n');
    }

    private generateDiagnosticSection(): string {
        const diags = this.registry.getDiagnostics();
        if (diags.length === 0) return "";

        return `\nDIAGNOSTICS:\n` + diags
            .map(d => ` [${d.code}] [${DiagnosticSeverity[d.severity]}] ${d.message}`)
            .join('\n');
    }

    private getLicenseTemplate(holder: string, year: string, attributions: string, diagnostics: string): string {
        return `MIT LICENSE\n` +
            `Copyright (c) ${year} ${holder}\n\n` +
            `Permission is hereby granted, free of charge, to any person obtaining a copy\n` +
            `of this software and associated documentation files (the "Software"), to deal\n` +
            `in the Software without restriction, including without limitation the rights\n` +
            `to use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n` +
            `copies of the Software, and to permit persons to whom the Software is\n` +
            `furnished to do so, subject to the following conditions:\n\n` +
            `The above copyright notice and this permission notice shall be included in all\n` +
            `copies or substantial portions of the Software.\n\n` +
            `ARCHITECTURAL_ATTRIBUTIONS:\n` +
            `${attributions}\n` +
            `${diagnostics}\n` +
            `THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n` +
            `IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n` +
            `FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n` +
            `AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER\n` +
            `LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,\n` +
            `OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE\n` +
            `SOFTWARE.`;
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// Bootstrap
// ─────────────────────────────────────────────────────────────────────────────

/**
 * @function bootstrapLicenseSystem
 *
 * Wires the full license subsystem in the correct dependency order:
 *
 *   1. Reset any stale container state (safe for hot-reload / test isolation)
 *   2. Instantiate SymbolRegistry with seed symbols from config
 *   3. Register SymbolRegistry into DependencyContainer
 *   4. Instantiate ComplianceValidator (resolves SymbolRegistry internally)
 *   5. Register ComplianceValidator into DependencyContainer
 *   6. Instantiate LicenseEmitter (resolves both above internally)
 *   7. Register LicenseEmitter into DependencyContainer
 *   8. Run compliance check against provided activeFlags
 *   9. Emit the license and return a BootstrapResult
 *
 * @param config - Bootstrap configuration surface
 * @returns BootstrapResult with emitted license, diagnostics, and live service refs
 *
 * @example
 * // Minimal — no symbols yet, defaults to full MIT flags
 * const result = bootstrapLicenseSystem({ holder: 'Craig Hckby', year: '2025' });
 *
 * @example
 * // With GROG siphoned symbols injected at runtime
 * const result = bootstrapLicenseSystem({
 *   holder: 'Craig Hckby',
 *   year:   '2025',
 *   symbols: grogBrain.getSiphonedSymbols(),
 *   activeFlags: LicenseFlags.All,
 *   strictMode: true
 * });
 * if (result.success) console.log(result.license);
 */
export function bootstrapLicenseSystem(config: BootstrapConfig): BootstrapResult {
    const {
        holder,
        year,
        symbols      = [],
        activeFlags  = LicenseFlags.Import | LicenseFlags.Merge | LicenseFlags.AttributionRequired,
        strictMode   = false
    } = config;

    // ── Step 1: Clean slate ────────────────────────────────────────────────
    DependencyContainer.reset();

    // ── Step 2 & 3: SymbolRegistry ─────────────────────────────────────────
    const registry = new SymbolRegistry(symbols);
    DependencyContainer.register<SymbolRegistry>('SymbolRegistry', registry);

    // ── Step 4 & 5: ComplianceValidator (needs SymbolRegistry in container) ─
    const validator = new ComplianceValidator();
    DependencyContainer.register<ComplianceValidator>('ComplianceValidator', validator);

    // ── Step 6 & 7: LicenseEmitter (needs both above in container) ─────────
    const emitter = new LicenseEmitter();
    DependencyContainer.register<LicenseEmitter>('LicenseEmitter', emitter);

    // ── Step 8: Compliance check ───────────────────────────────────────────
    const compliant = validator.validatePermissions(activeFlags);

    if (!compliant && strictMode) {
        throw new Error(
            `[LICENSE BOOTSTRAP] Strict mode: compliance check failed. ` +
            `Active flags: 0b${activeFlags.toString(2)}. ` +
            `Diagnostics: ${JSON.stringify(registry.getDiagnostics(), null, 2)}`
        );
    }

    // ── Step 9: Emit ───────────────────────────────────────────────────────
    const license = compliant ? emitter.emit(holder, year) : null;

    return {
        success:     compliant && registry.getStatus(),
        license,
        diagnostics: registry.getDiagnostics(),
        symbolCount: registry.listSymbols().length,
        services: { registry, validator, emitter }
    };
}

/**
 * @function addSiphonedSymbol
 * Convenience helper for GROG to inject a newly siphoned architectural symbol
 * into a live registry post-bootstrap without requiring a full re-bootstrap.
 *
 * @param symbol - The siphoned ArchitecturalSymbol to register
 *
 * @example
 * // After GROG siphons a new pattern from DeepMind/AlphaCode:
 * addSiphonedSymbol({
 *   id:           'deepmind-alphacode-001',
 *   repository:   'DeepMind/AlphaCode',
 *   contribution: 'Competitive programming pattern synthesis',
 *   timestamp:    Date.now(),
 *   checksum:     '<64-char-sha256>',
 *   flags:        LicenseFlags.Import | LicenseFlags.AttributionRequired,
 *   manifest: {
 *     method:    AcquisitionMethod.PreAiSiphon,
 *     originUrl: 'https://github.com/deepmind/alphacode',
 *     timestamp: Date.now(),
 *     depth:     1
 *   }
 * });
 */
export function addSiphonedSymbol(symbol: ArchitecturalSymbol): void {
    const registry = DependencyContainer.resolve<SymbolRegistry>('SymbolRegistry');
    registry.registerSymbol(symbol);
}
