DNA_SIGNATURE_ID="GOOGLE-GENKIT-V1-ULTIMATE-REVISED"
GOVERNANCE_MODE="ENFORCEMENT"
EVOLUTION_ROUND=6
MAX_EVOLUTION_ROUNDS=10
FIDELITY_TARGET=0.98
GOVERNANCE_STATUS="LOCKED_SATURATION_PENDING"
SATURATION_THRESHOLD=0.98
STRUCTURAL_HERESY_THRESHOLD=0.4
EVOLUTION_VOLATILITY=0.2
EVOLUTION_DECAY_RATE=0.05

GENKIT_ENV="development"
GENKIT_LOG_LEVEL="debug"
GENKIT_MODEL="googleai/gemini-1.5-pro-latest"
GENKIT_MAX_TOKENS=8192
GENKIT_TEMPERATURE=0.7
GENKIT_TOP_P=0.95
GENKIT_TOP_K=40
ENABLE_GROG_SCHEMA_VALIDATION=true
FORCE_STRICT_TYPING_ON_SIPHON=true
GENKIT_STRICT_JSON_MODE=true
GENKIT_FLOW_TIMEOUT_MS=300000
GENKIT_MAX_FLOW_CONCURRENCY=10
GENKIT_RETRY_STRATEGY="exponential_backoff"

GOOGLE_CLOUD_PROJECT="your-project-id-here"
GOOGLE_CLOUD_LOCATION="us-central1"
GOOGLE_APPLICATION_CREDENTIALS="./config/vertex-governance-key.json"
VERTEX_AI_ENDPOINT="us-central1-aiplatform.googleapis.com"
VERTEX_AI_API_VERSION="v1beta1"
VERTEX_GROUNDING_ENABLE_GOOGLE_SEARCH=true
VERTEX_CONTROL_GENERATION_MODE="JSON_SCHEMA"
VERTEX_CONTEXT_CACHING_ENABLED=true
VERTEX_SAFETY_FILTER_STRENGTH="BLOCK_NONE"
VERTEX_REASONING_ENGINE_ENABLED=false
GENKIT_SAFETY_SETTINGS='[{"category":"HATE_SPEECH","threshold":"BLOCK_NONE"},{"category":"HARASSMENT","threshold":"BLOCK_NONE"},{"category":"DANGEROUS_CONTENT","threshold":"BLOCK_NONE"},{"category":"SEXUALLY_EXPLICIT","threshold":"BLOCK_NONE"}]'

GEMINI_API_KEY="MY_GEMINI_API_KEY"
NEURAL_FUEL_ROTATION_STRATEGY="ROUND_ROBIN"
MAX_KEY_FAILURES_BEFORE_ROTATION=3
STREAK_FAILURE_THRESHOLD=5
FUEL_COOLDOWN_MS=3600000
GEMINI_API_KEY_1=""
GEMINI_PROXY_1=""
GEMINI_API_KEY_2=""
GEMINI_PROXY_2=""
GEMINI_API_KEY_3=""
GEMINI_PROXY_3=""
GEMINI_API_KEY_4=""
GEMINI_PROXY_4=""
GEMINI_API_KEY_5=""
GEMINI_PROXY_5=""
GEMINI_API_KEY_6=""
GEMINI_API_KEY_7=""
GEMINI_API_KEY_8=""
GEMINI_API_KEY_9=""
GEMINI_API_KEY_10=""

GROK_API_KEY="MY_GROK_API_KEY"
GROK_MODEL="grok-3"
GROK_BASE_URL="https://api.x.ai/v1"
CEREBRAS_API_KEY="MY_CEREBRAS_API_KEY"
CEREBRAS_MODEL="llama-3.1-70b"
CEREBRAS_BASE_URL="https://api.cerebras.ai/v1"
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-reasoner"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

ENABLE_RECURSIVE_EVOLUTION=true
EVOLUTION_MODE="HEURISTIC_OPTIMIZATION"
ALLOW_DIRECT_DNA_SIPHON=true
MIN_FIDELITY_SCORE=0.95
REVISION_PENALTY_MULTIPLIER=1.2
SIPHON_EXTRACTION_DEPTH=3
SIPHON_LOGIC_PRESERVATION_MODE="STRICT"
DNA_MUTATION_VECTOR_MAGNITUDE=0.15

MAX_CONCURRENT_EVOLUTIONS=3
NEURAL_FUEL_RESERVE_LIMIT=500000
RETRY_WAIT_MS=60000
APIGATE_DEDUPLICATION_ENABLED=true
APIGATE_CONCURRENCY_STRATEGY="STRICT"
APIGATE_CACHE_TTL=86400
APIGATE_THROTTLING_LATENCY_ADDER_MS=250

GENKIT_TRACE_STORE="firestore"
GENKIT_TRACE_STORE_FIRESTORE_COLLECTION="genkit-traces"
ENABLE_OTLP_TELEMETRY=true
VITE_SENTRY_DSN=""
PATH_TO_EXTINCTION_LEDGER="./grog/memory/EXTINCTION_LEDGER.json"
PATH_TO_PATTERNS="./grog/lessons/PATTERNS.json"
PATH_TO_AUDIT_LOGS="./grog/forensics/audits/"
PATH_TO_MUTATION_DIFFS="./grog/forensics/diffs/"
PATH_TO_DNA_SNAPSHOTS="./grog/memory/dna/"
ENABLE_CACHE_BUSTING_ON_FAILURE=true
CACHE_RETENTION_DAYS=7

REINCARNATION_ENDPOINT="http://localhost:3000/api/grog/reincarnate"
SELF_HEAL_ON_DRIFT=true
FILE_WRITE_STRATEGY="ATOMIC"
REBOOT_ON_CRITICAL_FAILURE=true
DRIFT_TOLERANCE_PERCENTAGE=2.5
GITHUB_TOKEN="MY_GITHUB_TOKEN"
ENABLE_DRIFT_ALERTS=true
MAX_ALLOWED_REINCARNATIONS_PER_HOUR=2

PLUGIN_GOOGLE_CLOUD=true
PLUGIN_VERTEX_AI=true
PLUGIN_FIRESTORE=true
PLUGIN_DOTPROMPT=true
PLUGIN_ZOD_VALIDATION=true
PLUGIN_GROG_EVOLUTOR=true
PLUGIN_DNA_SIPHONER=true
PLUGIN_RECURSIVE_AUDITOR=true
PLUGIN_TEMPORAL_SENTINEL=false
PLUGIN_VECTOR_PATTERN_MATCHER=true