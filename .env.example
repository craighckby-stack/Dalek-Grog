# Dalek-Grog Environment Configuration
# Copy this file to .env and fill in your values

# GitHub Personal Access Token
# Required scopes: repo, read:user
GITHUB_TOKEN=your_github_token_here

# Cerebras API Key (Fast LLM)
# Get it at: https://cerebras.ai
CEREBRAS_API_KEY=your_cerebras_key_here

# Grok API Key (Fallback LLM)
# Get it at: https://x.ai
GROK_API_KEY=your_grok_key_here

# Gemini API Key (Primary AI)
# Get it at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_key_here

# Optional: Firebase Config (for persistence)
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=

# Server Configuration
PORT=3000
NODE_ENV=development
