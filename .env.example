**ConfigManager.ts**
import { Config } from 'config';
import { resolvePath } from './utils/pathResolver';

export class ConfigManager {
  private readonly config: { [key: string]: string };
  private readonly cache: { [key: string]: { [key: string]: string } };

  constructor(config: { [key: string]: string }, cache: { [key: string]: { [key: string]: string } }) {
    this.config = config;
    this.cache = cache;
  }

  getEnvironmentVariable(name: string): string {
    return this.cache[name] ? this.cache[name][name] : this.config[name];
  }

  addEnvironmentVariable(name: string, value: string): void {
    this.config[name] = value;
    this.cache[name] = { [name]: value };
  }

  removeEnvironmentVariable(name: string): void {
    delete this.config[name];
    delete this.cache[name];
  }
}

export async function loadConfig(filePath: string): Promise<{ [key: string]: string }> {
  return require(resolvePath(filePath));
}

**pathResolver.ts**
const path = require('path');

export function resolvePath(target: string): string {
  const executablePath = process.execPath;
  const packagePath = require.main?.path;
  const packageDirectory = getPackageDirectory(packagePath);
  const targetPath = path.resolve(packageDirectory, target);
  return targetPath;
}

function getPackageDirectory(packagePath: string): string {
  const lastSlash = packagePath.lastIndexOf('/');
  if (lastSlash === -1) {
    return packagePath;
  }
  return packagePath.substring(0, lastSlash);
}

**index.ts**
import invariant from 'invariant';
import { isFunction } from 'lodash';
import { resolvePath } from './pathResolver';

function ensureConfig(): { [key: string]: string } {
  const filePath = resolvePath('.env.example');
  invariant(import.meta.require?.context?.requireFile?(filePath), 'Config file not found');
  return import.meta.require?.context?.requireFile!(filePath);
}

type Environment = { [key: string]: string } | { [key: string]: string }[];

const env = process.env as { [key: string]: string };
const config = ensureConfig();

function loadConfig(): void {
  const environment = {
    node_env: process.env.NODE_ENV || 'development',
    base_url: `${process.env.ENTRYPOINT}/v1`,
    __MODE__,
    __GEMINI_API_KEY__,
    __GITHUB_TOKEN__,
    __CEREBRAS_API_KEY__,
    __GROK_API_KEY__,
    __SENTRY_DSN__,
    __SCOPE_DB_CONNECTION_USER__,
    __SCOPE_DB_CONNECTION_PASSWORD__,
  };

  Object.assign(environment, config);
  global.__GEMINI_API_KEY__ = process.env.__GEMINI_API_KEY__ || 'default';
  process.env = {
    ...environment,
  };
}

