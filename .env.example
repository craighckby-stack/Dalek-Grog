class NexusFiberDiagonalizer {
  static instances = {};

  constructor(name, parentToken) {
    if (!NexusFiberDiagonalizer.instances[name]) {
      NexusFiberDiagonalizer.instances[name] = this;
    }
    NexusFiberDiagonalizer.instances[name].parentToken = parentToken;
    return NexusFiberDiagonalizer.instances[name];
  }

  getDiagnostics() {
    return this.history;
  }

  clear() {
    this.history = [];
  }

  cancel(reason) {
    this.cancelToken = reason;
  }

  isCancellationRequested(parentToken) {
    return this.cancelToken || (this.parentToken?.isCancellationRequested() ?? false);
  }

  throwIfCancelled(parentToken) {
    if (this.isCancellationRequested(parentToken)) {
      const error = new Error(this.cancelToken || 'OperationCanceledException');
      error.name = 'OperationCanceledException';
      throw error;
    }
  }
}

class NexusObjectPool {
  #pool;
  #limit;
  #ctor;
  #name;
  #diagnostics;

  constructor(ctor, name, diagnostics, limit = 10000) {
    this.#ctor = ctor;
    this.#name = name;
    this.#diagnostics = diagnostics;
    this.#limit = limit;
  }

  acquire(name, parentToken) {
    if (this.#pool.length > 0) {
      const instance = this.#pool.pop();
      instance.initialize();
      this.#diagnostics.emit('FIBER_REUSE', this.#name);
      return instance;
    }
    return new this.#ctor(parentToken);
  }

  release(instance) {
    if (this.#pool.length < this.#limit) {
      instance.cleanup();
      this.#pool.push(instance);
    } else {
      this.#diagnostics.emit('POOL_EXHAUSTED', this.#name);
    }
  }
}

class NexusFiberPool extends NexusObjectPool {
  constructor() {
    super(
      class NexusFiberEvolved extends Fiber {
        static instances = {};

        constructor(id, tag, type, props) {
          if (!NexusFiberEvolved.instances[id]) {
            NexusFiberEvolved.instances[id] = this;
          }
          this.init(id, tag, type, props);
          return NexusFiberEvolved.instances[id];
        }

        init(id, tag, type, props) {
          this.id = id;
          this.tag = tag;
          this.type = type;
          this.pendingProps = props;
          this.memoizedProps = null;
          this.flags = 0;
          this.lanes = 0;
          this.childLanes = 0;
          this.actualDuration = 0;
          this.actualStartTime = -1;
          this.treeBaseDuration = 0;
          this.deletions = null;
          this.index = 0;
          this.key = id;

          this.create();

          this.bindingLane = Lane.SyncLane;
        }

        create() {
          this.alternate = null;
          this.return = null;
          this.child = null;
          this.sibling = null;
          this.memoizedState = null;
          this.dependencies = null;
          this.updateQueue = null;
          this.stateNode = null;

          const laneManager = LaneManager.getInstance();

          this.lanes = laneManager.getLane(this.bindingLane).expirationTime;
        }

        cleanup() {
          this.pendingProps = null;
          this.memoizedProps = null;
          this.memoizedState = null;
          this.alternate = null;
          this.child = null;
          this.sibling = null;
          this.return = null;
          this.dependencies = null;
          this.updateQueue = null;
          this.stateNode = null;

          laneManager.removeLaneBinding(this.bindingLane);
        }
      },
      'NexusFiberEvolved',
      new NexusFiberDiagonalizer('NexusFiberPool')
    );
  }
}

class LaneManager {
  static laneManager = null;

  static getInstance() {
    if (!LaneManager.laneManager) {
      LaneManager.laneManager = new LaneManager();
    }
    return LaneManager.laneManager;
  }

  constructor() {
    this.lanes = {};
    this.currentTime = Date.now();
  }

  getLane(lane) {
    const expirationTime = this.getExpirationTime(lane, this.currentTime);
    this.lanes[lane].expirationTime = expirationTime;
    return this.lanes[lane];
  }

  getExpirationTime(lane, currentTime) {
    const expirationTimeMap = {
      SyncLane: currentTime + 500,
      InputContinuousLane: currentTime + 1000,
      DefaultLane: currentTime + 5000,
      IdleLane: currentTime + 10000,
    };

    return expirationTimeMap[lane] || currentTime + 5000;
  }

  updateExpirationTime(lane, newExpirationTime) {
    this.lanes[lane].expirationTime = newExpirationTime;
  }

  removeLaneBinding(lane) {
    delete this.lanes[lane];
  }
}

class Fiber {
  constructor(id, tag, type, props) {
    this.id = id;
    this.tag = tag;
    this.type = type;
    this.pendingProps = props;
    this.memoizedProps = null;
    this.flags = 0;
    this.lanes = 0;
    this.childLanes = 0;
    this.actualDuration = 0;
    this.actualStartTime = -1;
    this.treeBaseDuration = 0;
    this.deletions = null;
    this.index = 0;
    this.key = id;

    this.alternate = null;
    this.return = null;
    this.child = null;
    this.sibling = null;
    this.memoizedState = null;
    this.dependencies = null;
    this.updateQueue = null;
    this.stateNode = null;
  }
}

const Lane = {
  SyncLane: { name: 'SyncLane', expirationTime: 500 },
  InputContinuousLane: { name: 'InputContinuousLane', expirationTime: 1000 },
  DefaultLane: { name: 'DefaultLane', expirationTime: 5000 },
  IdleLane: { name: 'IdleLane', expirationTime: 10000 },
  NoLanes: null,
};

const diagonalizerPool = new NexusFiberPool();