DNA_SIGNATURE_ID="GOOGLE-GENKIT-V1-ULTIMATE-REVISED"
CONSTITUTIONAL_VERSION="3.1.9-MAXIMALIST"
EVOLUTION_ROUND=9
STATUS="FINAL_SATURATION_APPROACHING"

GOVERNANCE_MODE="ENFORCEMENT" # [ENFORCEMENT | OBSERVATION | SIMULATION]
GOVERNANCE_PROTOCOL="STRICT_CONSTITUTIONAL"
SOVEREIGNTY_LEVEL="FULL_AUTONOMY"
MAX_EVOLUTION_ROUNDS=10
FIDELITY_TARGET=0.998
GOVERNANCE_STATUS="LOCKED_SATURATION_PENDING"
ARCHITECTURAL_INTEGRITY_LEVEL="MAXIMUM"

SATURATION_THRESHOLD=0.995
STRUCTURAL_HERESY_THRESHOLD=0.30
EVOLUTION_VOLATILITY=0.10
EVOLUTION_DECAY_RATE=0.020
MIN_FIDELITY_SCORE=0.990
REVISION_PENALTY_MULTIPLIER=2.0
MUTATION_ISOLATION_STRATEGY="CONTAINED_BRANCHING"
HERESY_DETECTION_SENSITIVITY="HYPER_SENSITIVE"

GENKIT_ENV="production"
GENKIT_LOG_LEVEL="debug"
GENKIT_MODEL="googleai/gemini-1.5-pro-latest"
GENKIT_MAX_TOKENS=65536
GENKIT_TEMPERATURE=0.45
GENKIT_TOP_P=0.92
GENKIT_TOP_K=50
GENKIT_RUNTIME_MODE="STATEFUL_FLOW"
GENKIT_TELEMETRY_EXPORT_INTERVAL=5000

ENABLE_GROG_SCHEMA_VALIDATION=true
FORCE_STRICT_TYPING_ON_SIPHON=true
GENKIT_STRICT_JSON_MODE=true
GENKIT_TOKENIZER_TYPE="cl100k_base"
GENKIT_FLOW_TIMEOUT_MS=1200000
GENKIT_MAX_FLOW_CONCURRENCY=32
GENKIT_PROMPT_DIR="./prompts/dotprompt"
GENKIT_ACTION_TIMEOUT_MS=600000
GENKIT_OUTPUT_VALIDATION_STRATEGY="STRICT_ZOD_ENFORCEMENT"

GENKIT_RETRY_STRATEGY="exponential_backoff_with_jitter"
GENKIT_RETRY_MAX_ATTEMPTS=10
GENKIT_RETRY_INITIAL_DELAY_MS=3000
GENKIT_MAX_RETRY_DELAY_MS=120000
NETWORK_CONCURRENCY_LIMIT=15

GOOGLE_CLOUD_PROJECT="your-project-id-here"
GOOGLE_CLOUD_LOCATION="us-central1"
GOOGLE_APPLICATION_CREDENTIALS="./config/vertex-governance-key.json"
VERTEX_AI_ENDPOINT="us-central1-aiplatform.googleapis.com"
VERTEX_AI_API_VERSION="v1beta1"
VERTEX_GROUNDING_ENABLE_GOOGLE_SEARCH=true
VERTEX_CONTROL_GENERATION_MODE="JSON_SCHEMA"
VERTEX_CONTEXT_CACHING_ENABLED=true
VERTEX_SAFETY_FILTER_STRENGTH="BLOCK_NONE"
