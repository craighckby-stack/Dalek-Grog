class NexusFiber {
  parentToken;
  pendingProps;
  memoizedProps;
  alternate;

  constructor(parentToken, pendingProps, memoizedProps) {
    this.parentToken = parentToken;
    this.pendingProps = pendingProps;
    this.memoizedProps = memoizedProps;
  }

  initialize(parentToken, pendingProps, memoizedProps) {
    this.parentToken = parentToken;
    this.pendingProps = pendingProps;
    this.memoizedProps = memoizedProps;
  }

  cleanup() {
    this.pendingProps = null;
    this.memoizedProps = null;
  }

  getAlternateFiber() {
    return this.alternate;
  }

  setAlternateFiber(alternateFiber) {
    this.alternate = alternateFiber;
  }

  getCancellationToken() {
    return this.parentToken;
  }

  setParentToken(parentToken) {
    this.parentToken = parentToken;
  }

  getPendingProps() {
    return this.pendingProps;
  }

  setPendingProps(pendingProps) {
    this.pendingProps = pendingProps;
  }

  getMemoizedProps() {
    return this.memoizedProps;
  }

  setMemoizedProps(memoizedProps) {
    this.memoizedProps = memoizedProps;
  }
}

class NexusFiberPool {
  instances = {};

  static getInstance() {
    if (!NexusFiberPool.pool) {
      NexusFiberPool.pool = new NexusFiberPool();
    }
    return NexusFiberPool.pool;
  }

  constructor() {}

  getFiberInstance(fiberId) {
    return this.instances[fiberId];
  }

  setFiberInstance(fiberId, fiberInstance) {
    this.instances[fiberId] = fiberInstance;
  }

  releaseFiber(fiberInstance) {
    this.removeFiberInstance(fiberInstance.id);
  }

  removeFiberInstance(fiberId) {
    delete this.instances[fiberId];
  }

  acquireFiber(parentToken, pendingProps, memoizedProps) {
    const fiberInstance = this.getFiberInstance(NexusFiber.getNextFreeFiberId());
    if (fiberInstance) {
      fiberInstance.initialize(parentToken, pendingProps, memoizedProps);
      return fiberInstance;
    } else {
      const newFiber = new NexusFiber(parentToken, pendingProps, memoizedProps);
      this.setFiberInstance(NexusFiber.getNextFreeFiberId(), newFiber);
      return newFiber;
    }
  }
}

class LaneManager {
  lanes = {};

  static getInstance() {
    if (!LaneManager.laneManager) {
      LaneManager.laneManager = new LaneManager();
    }
    return LaneManager.laneManager;
  }

  constructor() {}

  getLane(lane) {
    Lane.getExpirationTime(lane, Date.now());
    return this.lanes[lane];
  }

  bindLane(fiberInstance, laneId) {
    fiberInstance.lane = laneId;
    this.lanes[laneId].addFiber(fiberInstance);
  }

  releaseLaneBinding(laneId) {
    delete this.lanes[laneId];
  }

  getNextFreeLane() {
    let lane;
    for (let l in this.lanes) {
      if (Lane.isFree(this.lanes[l])) {
        lane = l;
        break;
      }
    }
    return lane || Lane.NoLanes;
  }

  releaseFiber(fiberInstance) {
    this.lanes[fiberInstance.lane].removeFiber(fiberInstance);
  }
}

class Lane {
  static NoLanes = 0;
  static SyncLane = 1;
  static InputContinuousLane = 2;
  static DefaultLane = 3;
  static IdleLane = 4;
  static scheduled = { [Lane.NoLanes]: false, [Lane.SyncLane]: false, [Lane.InputContinuousLane]: false, [Lane.DefaultLane]: false, [Lane.IdleLane]: false };

  fibers = [];

  constructor() {}

  addFiber(fiberInstance) {
    this.fibers.push(fiberInstance);
  }

  removeFiber(fiberInstance) {
    this.fibers = this.fibers.filter(f => f !== fiberInstance);
  }

  isFree() {
    const self = this;
    return (Date.now() - self.expirationTime) > 0;
  }

  getExpirationTime(lane, currentTime) {
    switch (lane) {
      case Lane.SyncLane:
        return currentTime + 500;
      case Lane.InputContinuousLane:
        return currentTime + 1000;
      case Lane.DefaultLane:
        return currentTime + 5000;
      case Lane.IdleLane:
        return currentTime + 10000;
      default:
        return currentTime + 5000;
    }
  }

  isScheduled(lane) {
    if (!Lane.scheduled[lane]) {
      Lane.scheduled[lane] = true;
    } else {
      return true;
    }
    return false;
  }

  reschedule(lane) {
    Lane.scheduled[lane] = true;
  }
}