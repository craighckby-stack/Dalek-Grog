# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Multi-Key Rotation & Proxy Support
GEMINI_API_KEY_1=
GEMINI_PROXY_1=
GEMINI_API_KEY_2=
GEMINI_PROXY_2=
GEMINI_API_KEY_3=
GEMINI_PROXY_3=
GEMINI_API_KEY_4=
GEMINI_PROXY_4=
GEMINI_API_KEY_5=
GEMINI_PROXY_5=

# GITHUB_TOKEN: Required for GitHub API calls.
GITHUB_TOKEN="MY_GITHUB_TOKEN"

# CEREBRAS_API_KEY: Required for Cerebras AI API calls.
CEREBRAS_API_KEY="MY_CEREBRAS_API_KEY"

# GROK_API_KEY: Required for Grok AI API calls.
GROK_API_KEY="MY_GROK_API_KEY"

# Sentry DSN for error monitoring
VITE_SENTRY_DSN=
