### jsonfile Example Usage

*   `const file = require('jsonfile');`
*   `file Seth file, options, callback);`

const fs = require('fs');
const jsonfile = require('jsonfile');
const Logger = require('./Logger');
type EnvEntry = {
  [key: string]: string;
};

type Environment = Record<string, EnvEntry>;

class EnvDumper {
  static async dump() {
    try {
      const env = await EnvDumper.getEnvironment();
      const envData: Environment = {};
      await Promise.all(
        Object.entries(env).map(async ([key, value]) => {
          envData[key] = { value };
        })
      );

      const envDump = jsonfile.stringify(envData);
      Logger.info(`Environment dump saved to env_dump.json`);
      return envDump;
    } catch (error) {
      Logger.error(`Error dumping environment: ${error.message}`);
      return null;
    }
  }

  static async getEnvironment(): Promise<Environment> {
    const env = process.env;
    return Promise.resolve(env);
  }
}

module.exports = EnvDumper;

