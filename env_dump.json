### jsonfile Example Usage

*   `const file = require('jsonfile');`
*   `fileيث file, options, callback);`

const fs = require('fs');
const jsonfile = require('jsonfile');
const Logger = require('./Logger');

class EnvDumper {
  static dump() {
    try {
      const env = process.env;
      const envData = Object.entries(env).reduce((acc, [key, value]) => {
        acc[key] = { value };
        return acc;
      }, {});

      const envDump = jsonfile.stringify(envData);
      Logger.info(`Environment dump saved to env_dump.json`);
      return envDump;
    } catch (error) {
      Logger.error(`Error dumping environment: ${error.message}`);
      return null;
    }
  }
}

module.exports = EnvDumper;


