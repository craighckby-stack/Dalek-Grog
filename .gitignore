class NexusCoreMutation extends NexusCore {
  constructor(config) {
    super(config);
    this.#plugins = new Map();
    this.#pluginStore = new NexusPluginStore(this.#program.host);
    this.#pluginStore.addPlugin(new MedullaPlugin());
  }

  async start() {
    try {
      await super.start();
      await this.#initializePluginQueue();
    } catch (e) {
      this.#handleError(e);
    }
  }

  #initializePluginQueue() {
    this.#pluginQueue = new Queue(this.#pluginStore.getPlugins());
  }

  async #handlePluginActivation() {
    const nextPlugin = this.#pluginQueue.getNext();
    if (!nextPlugin) return;
    const { name, fn } = nextPlugin;
    try {
      await fn();
      this.#pluginQueue.remove(nextPlugin);
    } catch (e) {
      this.#handleError(e);
    }
  }

  async #handleError(e) {
    console.error(e);
    this.#handlePluginActivation();
  }
}

class UniEventBus extends EventEmitter {
  constructor(program) {
    super();
    this.#program = program;
    this.#eventBus = new NexusEventBus(this.#program);
  }

  async registerListener(listener, listenerName) {
    try {
      await this.#eventBus.registerListener(listener, listenerName);
    } catch (e) {
      this.#handleError(e);
    }
  }

  async dispatchEvent(eventName, message, options) {
    try {
      await this.#eventBus.dispatchEvent(eventName, message, options);
    } catch (e) {
      this.#handleError(e);
    }
  }

  #handleError(e) {
    console.error(e);
  }
}

class MedullaPlugin extends NexusPlugin {
  async activate() {
    // Plugin activation logic here
  }
}

class NexusCoreMedulla extends NexusCore {
  constructor(config) {
    super(config);
  }

  async start() {
    try {
      await super.start();
    } catch (e) {
      console.error(e);
    }
  }
}